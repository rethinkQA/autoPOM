{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "bin/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "tsBuildInfoFile": "dist/.tsbuildinfo"
}
